# =====================================================================
# Plantilla de variables de entorno del sistema HMS
#
# Este archivo SÍ va a git (no tiene valores reales). Sirve como
# "checklist" para saber qué configurar en Streamlit Cloud / Supabase
# / GitHub Actions cuando migremos.
#
# En tu Mac de desarrollo, copiá este archivo como `.env` y llenalo
# con los valores reales:
#     cp .env.example .env
# Y después NUNCA lo agregues a git (el .gitignore ya lo bloquea).
# =====================================================================

# ─── API de Anthropic (Claude) ───
ANTHROPIC_API_KEY=sk-ant-...

# ─── SMTP para emails ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASSWORD=tu-app-password
SMTP_FROM=HMS Nutrición Animal <tu-email@gmail.com>
SMTP_BCC_ADMIN=hms002@gmail.com

# ─── IMAP para procesar bajas automáticamente ───
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=tu-email@gmail.com
IMAP_PASSWORD=tu-app-password

# ─── WhatsApp Twilio ───
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_ADMIN_WHATSAPP=whatsapp:+549...

# ─── WeatherAPI.com ───
WEATHERAPI_KEY=...

# ─── Base de datos (llegará con la migración a Supabase) ───
# Mientras tanto, el sistema usa data/cattle_tracker.db localmente
# y ese archivo NO se sube a git.
# DATABASE_URL=postgresql://user:pass@host:5432/db
