# =====================================================================
# Plantilla de secrets para Streamlit Cloud — HMS Nutrición Animal
# =====================================================================
# Cómo se usa:
#
#   1. NO cargues valores reales en este archivo — es solo checklist.
#   2. En Streamlit Cloud (https://share.streamlit.io/) entrás a tu app,
#      click en "⋮" → "Settings" → tab "Secrets" y pegás el contenido
#      de acá reemplazando los valores por los reales.
#   3. La app los lee via st.secrets["clave"] o via os.environ (porque
#      Streamlit los expone también como env vars).
#
# El adapter `src/db_backend.py` detecta DATABASE_URL en env y activa
# el modo Postgres automáticamente. Con estos secrets configurados, la
# app funciona igual que en tu Mac pero contra Supabase.
# =====================================================================

# ─── Base de datos (Supabase Postgres) ───
DATABASE_URL = "postgresql://postgres.<REF>:<PASSWORD>@aws-1-us-west-2.pooler.supabase.com:5432/postgres"

# ─── API de Anthropic (Claude) ───
ANTHROPIC_API_KEY = "sk-ant-api03-..."

# ─── SMTP para emails ───
SMTP_HOST = "smtp.gmail.com"
SMTP_PORT = "587"
SMTP_USER = "tu-email@gmail.com"
SMTP_PASSWORD = "app-password-generado-en-google"
SMTP_FROM = "HMS Nutrición Animal <tu-email@gmail.com>"
SMTP_BCC_ADMIN = "hms002@gmail.com"

# ─── IMAP (procesar bajas por email) ───
IMAP_HOST = "imap.gmail.com"
IMAP_PORT = "993"
IMAP_USER = "tu-email@gmail.com"
IMAP_PASSWORD = "mismo-app-password"

# ─── WhatsApp (Twilio) ───
TWILIO_ACCOUNT_SID = "AC..."
TWILIO_AUTH_TOKEN = "..."
TWILIO_WHATSAPP_FROM = "whatsapp:+14155238886"
TWILIO_ADMIN_WHATSAPP = "whatsapp:+549..."

# ─── WeatherAPI.com ───
WEATHERAPI_KEY = "..."
